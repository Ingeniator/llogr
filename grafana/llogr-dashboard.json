{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus" },
    { "type": "panel", "id": "timeseries", "name": "Time series" },
    { "type": "panel", "id": "stat", "name": "Stat" },
    { "type": "panel", "id": "table", "name": "Table" }
  ],
  "id": null,
  "uid": "llogr-overview",
  "title": "llogr Overview",
  "description": "Request rates, latencies, error rates, and backend health for llogr",
  "tags": ["llogr", "prometheus"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(http_requests_total, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "handler",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(http_requests_total{instance=~\"$instance\"}, handler)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "title": "",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Request Rate",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "thresholds": { "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": ""
        }
      ]
    },
    {
      "title": "Error Rate (5xx)",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.01 }] }
        },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{instance=~\"$instance\", status=~\"5..\"}[$__rate_interval]))",
          "legendFormat": ""
        }
      ]
    },
    {
      "title": "P95 Latency",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{instance=~\"$instance\"}[$__rate_interval])) by (le))",
          "legendFormat": ""
        }
      ]
    },
    {
      "title": "Events Ingested / min",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "blue", "value": null }] } },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(rate(llogr_events_ingested_total{instance=~\"$instance\"}[$__rate_interval])) * 60",
          "legendFormat": ""
        }
      ]
    },
    {
      "title": "",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Request Rate by Handler",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "sum by (handler) (rate(http_requests_total{instance=~\"$instance\", handler=~\"$handler\"}[$__rate_interval]))",
          "legendFormat": "{{ handler }}"
        }
      ]
    },
    {
      "title": "Request Rate by Status Code",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "stacking": { "mode": "normal" } } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "2.." }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "4.." }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "5.." }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_requests_total{instance=~\"$instance\", handler=~\"$handler\"}[$__rate_interval]))",
          "legendFormat": "{{ status }}"
        }
      ]
    },
    {
      "title": "",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Request Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{instance=~\"$instance\", handler=~\"$handler\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{instance=~\"$instance\", handler=~\"$handler\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{instance=~\"$instance\", handler=~\"$handler\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Request Latency by Handler (p95)",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, handler) (rate(http_request_duration_seconds_bucket{instance=~\"$instance\", handler=~\"$handler\"}[$__rate_interval])))",
          "legendFormat": "{{ handler }}"
        }
      ]
    },
    {
      "title": "",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Events Ingested by Project",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 15, "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "sum by (project_id) (rate(llogr_events_ingested_total{instance=~\"$instance\"}[$__rate_interval])) * 60",
          "legendFormat": "{{ project_id }}"
        }
      ]
    },
    {
      "title": "S3 Save Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(llogr_s3_save_seconds_bucket{instance=~\"$instance\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(llogr_s3_save_seconds_bucket{instance=~\"$instance\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(llogr_s3_save_seconds_bucket{instance=~\"$instance\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Clickbeat Forward Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(llogr_clickbeat_forward_seconds_bucket{instance=~\"$instance\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(llogr_clickbeat_forward_seconds_bucket{instance=~\"$instance\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(llogr_clickbeat_forward_seconds_bucket{instance=~\"$instance\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "S3 Save Error Rate",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 33 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 15 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(llogr_s3_save_errors_total{instance=~\"$instance\"}[$__rate_interval])) * 60",
          "legendFormat": "errors/min"
        }
      ]
    },
    {
      "title": "Clickbeat Forward Error Rate",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 33 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 15 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(llogr_clickbeat_forward_errors_total{instance=~\"$instance\"}[$__rate_interval])) * 60",
          "legendFormat": "errors/min"
        }
      ]
    },
    {
      "title": "Request / Response Size (p95)",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 33 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_size_bytes_bucket{instance=~\"$instance\"}[$__rate_interval])) by (le))",
          "legendFormat": "request p95"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_response_size_bytes_bucket{instance=~\"$instance\"}[$__rate_interval])) by (le))",
          "legendFormat": "response p95"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
